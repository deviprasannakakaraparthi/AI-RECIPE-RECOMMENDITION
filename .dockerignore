# Exclude EVERYTHING large and unnecessary
*.zip
*.tflite
*.csv
*.pkl
*.pt
android/
android_sdk/
frontend_flutter/
frontend_web/
web/
.agents/
.git/
.DS_Store

# Explicitly block all venvs
**/venv/
**/ENV/
**/.env
**/.venv/
venv/
backend/venv/

# Python junk
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Logs
*.log
backend/*.log
static/videos/*.mp4

# Pre-built Flutter UI is in backend/static/web, keep that but ignore others
!backend/static/web/
!recipes_cleaned.csv
!backend/yolov8n.pt
!backend/recipe_embeddings.pkl
!backend/indian_recipe_embeddings.pkl
!backend/Cleaned_Indian_Food_Dataset_embeddings.pkl
